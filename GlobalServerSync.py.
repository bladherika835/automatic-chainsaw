class GlobalServerManager:
    """
    Manages regional synchronization for the Super-Server.
    Connecting: EU (Sweden), Canada, Australia, and New Zealand.
    """
    def __init__(self):
        self.active_regions = ["Sweden", "Canada", "New Zealand", "Australia"]
        self.server_status = "Online"

    def connect_to_ice_world(self, player_id, region):
        if region in self.active_regions:
            print(f"Connecting Player {player_id} to the {region} cluster...")
            return f"Success: Connected to {region} Ice World Server."
        else:
            return "Error: Region not supported by Starlight Dev."

